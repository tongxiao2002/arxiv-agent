# Arxiv-Agent Environment Variables
# Copy this file to .env and fill in your API keys
# Never commit .env to version control!

# ===== LLM Provider API Keys =====
# Choose one provider based on config.yaml llm.provider setting

# OpenAI (if using OpenAI models)
# OPENAI_API_KEY="sk-..."

# Anthropic (if using Claude models)
# ANTHROPIC_API_KEY="sk-ant-..."

# DeepSeek (if using DeepSeek models)
# DEEPSEEK_API_KEY="sk-..."

# ===== Email Service API Keys =====
# Choose one service based on config.yaml email.service setting

# SendGrid (if using SendGrid)
# SENDGRID_API_KEY="SG...."

# Mailgun (if using Mailgun)
# MAILGUN_API_KEY="key-..."
# MAILGUN_DOMAIN="sandbox....mailgun.org"

# ===== Optional Configuration =====
# Timezone for scheduling (default: Asia/Shanghai)
# TZ="Asia/Shanghai"

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL="INFO"

# Maximum retries for network operations
# MAX_RETRIES="5"

# Retry backoff factor (exponential backoff)
# RETRY_BACKOFF_FACTOR="2"